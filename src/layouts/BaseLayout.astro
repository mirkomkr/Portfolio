---
import '../styles/global.css';
import '@fontsource-variable/open-sans';
import '@fontsource-variable/playfair-display';
import { SEO } from 'astro-seo';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
}

const {
  title,
  description,
  canonical = 'https://www.mirkopasseri.it',
  ogImage = 'https://www.mirkopasseri.it/mirko-passeri-frontend-developer.webp',
  ogImageAlt = 'Mirko Passeri — Frontend Developer & Web Designer',
} = Astro.props;

const baseSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://www.mirkopasseri.it/#persona",
      "name": "Mirko Passeri",
      "jobTitle": "Frontend Developer",
      "url": "https://www.mirkopasseri.it",
      "image": "https://www.mirkopasseri.it/mirko-passeri-frontend-developer.webp",
      "sameAs": [
        "https://www.linkedin.com/in/mirko-passeri/",
        "https://github.com/mirkomkr"
      ],
      "description": "Frontend Developer con base ad Anzio, specializzato nella creazione di siti web performanti, accessibili e ottimizzati per i motori di ricerca.",
      "knowsAbout": ["HTML", "CSS", "JavaScript", "React", "Astro", "Next.js", "Web Accessibility", "SEO"],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Anzio",
        "addressRegion": "Lazio",
        "addressCountry": "IT"
      }
    },
    {
      "@type": "WebSite",
      "@id": "https://www.mirkopasseri.it/#website",
      "url": "https://www.mirkopasseri.it",
      "name": "Mirko Passeri",
      "description": "Portfolio e blog di Mirko Passeri, Frontend Developer ad Anzio.",
      "author": { "@id": "https://www.mirkopasseri.it/#persona" },
      "inLanguage": "it"
    }
  ]
};
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Mirko Passeri" />
    <meta name="google-site-verification" content="JTVN5TjnWgrOKZasixKrMiB0Vut79SXjvAUbB67eu-Y" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      openGraph={{
        basic: { title, type: 'website', image: ogImage },
        optional: { description, locale: 'it_IT', siteName: 'Mirko Passeri' },
        image: { alt: ogImageAlt, width: 1200, height: 630 },
      }}
      twitter={{
        card: 'summary_large_image',
        title,
        description,
        image: ogImage,
        imageAlt: ogImageAlt,
      }}
    />
    <link rel="alternate" hreflang="it" href={canonical} />
    <link rel="alternate" hreflang="x-default" href="https://www.mirkopasseri.it/" />
    <script type="application/ld+json" set:html={JSON.stringify(baseSchema)}></script>
    <slot name="schema" />
  </head>
  <body class="bg-master text-primary antialiased scroll-smooth">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:z-50 focus:top-4 focus:left-4 focus:px-5 focus:py-3 focus:bg-primary focus:text-master focus:rounded-md focus:font-semibold focus:text-sm focus:shadow-lg"
    >
      Vai al contenuto principale
    </a>
    <div id="main-content" tabindex="-1">
      <slot />
    </div>
    <Footer />

    <button
      id="torna-su"
      aria-label="Torna in cima alla pagina"
      class="fixed bottom-8 right-8 z-50 flex items-center justify-center w-11 h-11 rounded-full bg-primary text-master shadow-lg opacity-0 pointer-events-none transition-all duration-300 hover:bg-primary/80 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-master"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 8.586l-6.293 6.293-1.414-1.414L12 5.757l7.707 7.708-1.414 1.414z"/>
      </svg>
    </button>

    <script is:inline>
      const btn = document.getElementById('torna-su');
      if (btn) {
        window.addEventListener('scroll', () => {
          const visible = window.scrollY > 400;
          btn.style.opacity = visible ? '1' : '0';
          btn.style.pointerEvents = visible ? 'auto' : 'none';
        }, { passive: true });
        btn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    </script>
  </body>
</html>
