---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const latestPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section id="blog" aria-labelledby="titolo-blog" class="flex flex-col justify-center items-center md:items-end w-full min-h-screen max-w-7xl mx-auto px-8 md:px-24 py-20">

  <h2 id="titolo-blog" class="font-title text-center md:text-right w-full text-4xl md:text-6xl mb-16 md:mb-24 text-primary">
    Blog
  </h2>

  <ul class="w-full space-y-10">
    {latestPosts.map((post) => (
      <li class="group border-b border-primary/10 pb-10">
        <article>
          <h3 class="font-title text-xl md:text-3xl text-primary mb-3 group-hover:text-accent transition-colors duration-300">
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          </h3>
          <p class="text-primary/75 leading-relaxed max-w-2xl text-base">{post.data.description}</p>
        </article>
      </li>
    ))}
  </ul>

  <div class="mt-16 md:self-end">
    <a
      href="/blog/"
      class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-widest text-accent border border-accent/40 px-6 py-3 rounded-md hover:bg-accent hover:text-master transition-all duration-300"
      aria-label="Vai a tutti gli articoli del blog"
    >
      Tutti gli articoli →
    </a>
  </div>

</section>
