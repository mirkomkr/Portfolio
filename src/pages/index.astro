---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Progetti from '../components/Progetti.astro';
import ChiSonoPreview from '../components/ChiSonoPreview.astro';
import BlogPreview from '../components/BlogPreview.astro';
import Timeline from '../components/Timeline.astro';
import Contatti from '../components/Contatti.astro';
---

<BaseLayout
  title="Mirko Passeri — Frontend Developer & Web Designer ad Anzio"
  description="Portfolio di Mirko Passeri: sviluppo siti web moderni, accessibili e ottimizzati per Google. Anzio, Nettuno e zone limitrofe."
  canonical="https://www.mirkopasseri.it"
>
  <main>
    <section aria-label="Introduzione" class="hero">
      <Hero />
    </section>
    <section aria-label="Contenuti principali">
      <ChiSonoPreview />
      <Progetti />
      <BlogPreview />
      <Timeline />
      <Contatti />
    </section>
  </main>
</BaseLayout>
