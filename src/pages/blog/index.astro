---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog — Note e Guide Web di Mirko Passeri"
  description="Articoli su sviluppo web, accessibilità, SEO e performance. Scritti per chiunque voglia capire il web — con o senza background tecnico."
  canonical="https://www.mirkopasseri.it/blog/"
>
  <main class="min-h-screen max-w-7xl mx-auto px-8 md:px-24 py-20">

    <header class="mb-16 md:mb-24">
      <a href="/" class="inline-block text-xs font-semibold uppercase tracking-widest text-accent hover:underline mb-8">
        ← Torna alla home
      </a>
      <h1 class="font-title text-5xl md:text-7xl text-primary leading-tight">
        Blog
      </h1>
      <p class="mt-4 text-lg text-primary/75 max-w-xl">
        Note su web design, accessibilità e come costruire cose che funzionano davvero.
      </p>
    </header>

    {sortedPosts.length === 0 ? (
      <p class="text-primary/75">Nessun articolo ancora. Torna presto.</p>
    ) : (
      <ul class="space-y-12">
        {sortedPosts.map((post) => (
          <li class="group border-b border-primary/10 pb-12">
            <article>
              <h2 class="font-title text-2xl md:text-4xl text-primary mt-2 mb-3 group-hover:text-accent transition-colors duration-300">
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </h2>
              <p class="text-primary/75 leading-relaxed max-w-2xl">{post.data.description}</p>
            </article>
          </li>
        ))}
      </ul>
    )}

  </main>
</BaseLayout>
